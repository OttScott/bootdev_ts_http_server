{
  "name": "bootdev_ts_http_server",
  "version": "1.0.0",
  "description": "BootDev HTTP Server in TypeScript",
  "keywords": [
    "TypeScript",
    "BootDev",
    "HTTP",
    "Server"
  ],
  "homepage": "https://github.com/OttScott/bootdev_ts_http_server#readme",
  "bugs": {
    "url": "https://github.com/OttScott/bootdev_ts_http_server/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OttScott/bootdev_ts_http_server.git"
  },
  "license": "ISC",
  "author": "Scott Ott",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "test": "vitest --run",
    "build": "npx tsc",
    "start": "node dist/index.js",
    "dev": "npx tsc && node dist/index.js",
    "db:start": "wsl sudo service postgresql start",
    "db:stop": "wsl sudo service postgresql stop",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.2",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.2",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "postgres": "^3.4.9"
  }
}
